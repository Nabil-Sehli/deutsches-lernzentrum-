# ── Backend ─────────────────────────────────────────────────────
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── S3 (Image Upload) ───────────────────────────────────────────
S3_ENDPOINT=              # S3-compatible endpoint (optional, e.g. http://localhost:9000 for MinIO)
S3_REGION=                # S3 region
S3_BUCKET=                # S3 bucket name
S3_ACCESS_KEY_ID=         # S3 access key
S3_SECRET_ACCESS_KEY=     # S3 secret key
S3_PUBLIC_URL=            # Public URL prefix for uploaded files (e.g. https://my-bucket.s3.amazonaws.com)

# ── SendGrid (Email Verification) ───────────────────────────────
SENDGRID_API_KEY=          # SendGrid API key for sending verification emails
SENDGRID_FROM_EMAIL=       # From email address for verification emails
